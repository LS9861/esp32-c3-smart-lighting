# Auto-detect text files
* text=auto

# Source code
*.cpp text eol=lf
*.c text eol=lf
*.h text eol=lf
*.ino text eol=lf
*.pde text eol=lf

# Configuration files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# Documentation
*.md text eol=lf diff=markdown
*.txt text eol=lf
*.rst text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.bz2 binary

# PlatformIO specific
*.hex binary
*.bin binary
*.elf binary
*.a binary
*.o binary
*.d binary